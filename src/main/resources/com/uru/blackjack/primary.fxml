<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #2d5a27;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uru.blackjack.PrimaryController">
    <children>
        <Label text="URU BLACKJACK CASINO" textFill="WHITE" style="-fx-font-weight: bold;"/>
        <HBox fx:id="hbPlayerCards" alignment="CENTER" spacing="10" minHeight="100"/>
        <Label fx:id="lblPlayerScore" text="Puntaje: 0" textFill="WHITE"/>
        <Label fx:id="lblStatus" text="Esperando inicio..." textFill="YELLOW"/>
        <HBox alignment="CENTER" spacing="10">
            <Button text="Nueva Partida" onAction="#startGame" />
            <Button fx:id="btnHit" text="Pedir" onAction="#handleHit" disable="true" />
            <Button fx:id="btnStand" text="Plantarse" onAction="#handleStand" disable="true" />
        </HBox>
    </children>
</VBox>